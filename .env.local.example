# Per-workspace isolation overrides.
#
# This file is a TEMPLATE. Parallel worktrees get a generated `.env.local`
# (git-ignored) from scripts/agent/setup-worktree.sh with unique free ports.
# Never commit `.env.local`. Never edit the ports by hand — let the script pick them.
#
# Prefer: bash scripts/agent/setup-workspace.sh <slug>
# (solo on idle primary; worktree when primary is busy — see ADR 0004)
#
# The primary checkout can run without any .env.local: docker-compose and
# vite.config.js fall back to the default ports shown below.

# --- Host-published ports (must be unique per worktree) ---
POSTGRES_PORT=5432
REDIS_PORT=6379
API_PORT=8000
FRONTEND_PORT=5173

# --- Compose project name (isolates containers/volumes/networks per worktree) ---
# setup-worktree.sh sets this to the sanitized branch name.
COMPOSE_PROJECT_NAME=imoveis

# --- API edge credential (required for SPA favourites / watchlist / admin) ---
# Paste this same value into the sidebar "API credential" field after opening the UI.
# Never commit real production secrets. Restart the stack after changing this.
API_KEY=local-dev-api-key
